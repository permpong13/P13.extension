<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:s="clr-namespace:System;assembly=mscorlib"
        Title="{DynamicResource Spectrum.Title}"
        Height="670" Width="560" MinWidth="560" MaxWidth="560" MinHeight="670"
        ShowInTaskbar="True" ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen" Topmost="True"
        Background="#F5F5F7" FontFamily="Segoe UI" FontSize="12" Foreground="#1C1C1E">
    <Window.Resources>
        <Style x:Key="MacButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1C1C1E"/>
            <Setter Property="BorderBrush" Value="#C7C7CC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5E5EA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D1D1D6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MacPrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#007AFF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#007AFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#006DE0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0056B3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#C7C7CC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#C7C7CC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#C7C7CC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0" Grid.Row="0">
            <TextBlock x:Name="_txt_block2" Text="{DynamicResource Spectrum.Labels.CategorySelection}" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <ComboBox x:Name="_categories" Height="28" Margin="0,0,0,16" DisplayMemberPath="Key"/>

            <TextBlock x:Name="_txt_block3" Text="{DynamicResource Spectrum.Labels.ParameterSelection}" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox x:Name="_search_box" Height="28" Margin="0,0,0,6" GotFocus="search_box_enter" LostFocus="search_box_leave" TextChanged="on_search_text_changed"/>
            <ComboBox x:Name="_list_box1" Height="28" Margin="0,0,0,16" DisplayMemberPath="Key" SelectionChanged="check_item"/>
        </StackPanel>

        <StackPanel Grid.Column="2" Grid.Row="0">
            <TextBlock x:Name="_lbl_manage_schemes" Text="{DynamicResource Spectrum.Labels.ManageSchemes}" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Button x:Name="_button_save_load_scheme" Content="{DynamicResource Spectrum.Buttons.SaveLoadScheme}" Height="28" Style="{StaticResource MacButtonStyle}" Margin="0,0,0,16" Click="save_load_color_scheme"/>

            <TextBlock x:Name="_lbl_generate_colors" Text="{DynamicResource Spectrum.Labels.GenerateColors}" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Button x:Name="_button_gradient_colors" Content="{DynamicResource Spectrum.Buttons.GradientColors}" Height="28" Style="{StaticResource MacButtonStyle}" Margin="0,0,0,6" Click="button_click_gradient_colors"/>
            
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="_combo_themes" Grid.Column="0" Height="28">
                    <ComboBoxItem Content="Pastel Theme" IsSelected="True"/>
                    <ComboBoxItem Content="Vibrant Theme"/>
                    <ComboBoxItem Content="Dark Theme"/>
                    <ComboBoxItem Content="Earthy Theme"/>
                </ComboBox>
                <Button x:Name="_button_apply_theme" Grid.Column="2" Content="Apply Theme" Height="28" Style="{StaticResource MacButtonStyle}" Click="button_click_apply_theme"/>
            </Grid>
            
            <Button x:Name="_button_random_colors" Content="{DynamicResource Spectrum.Buttons.RandomColors}" Height="28" Style="{StaticResource MacButtonStyle}" Margin="0,0,0,16" Click="button_click_random_colors"/>
        </StackPanel>

        <StackPanel Grid.Column="0" Grid.Row="1">
            <TextBlock x:Name="_txt_block4" Text="{DynamicResource Spectrum.Labels.ValuesColorAssignment}" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock x:Name="_txt_shift_click_hint" Text="{DynamicResource Spectrum.Messages.ShiftClickToSelect}" Foreground="#8E8E93" FontSize="11" Margin="0,0,0,8"/>
        </StackPanel>

        <StackPanel Grid.Column="2" Grid.Row="1">
            <TextBlock x:Name="_lbl_apply_settings" Text="{DynamicResource Spectrum.Labels.ApplySettings}" FontWeight="SemiBold" Margin="0,0,0,12"/>
        </StackPanel>

        <Grid Grid.Column="0" Grid.Row="2">
            <ListBox x:Name="list_box2" DisplayMemberPath="Key" VerticalAlignment="Stretch" Margin="0,0,0,10"/>
            <TextBlock x:Name="_txt_placeholder_values" 
                       Text="{DynamicResource Spectrum.Placeholders.SelectCategoryAndParameter}" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" 
                       Foreground="#8E8E93" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="220" 
                       IsHitTestVisible="False"/>
        </Grid>

        <StackPanel Grid.Column="2" Grid.Row="2">
            <CheckBox x:Name="_chk_line_color" Content="{DynamicResource Spectrum.Checkboxes.ApplyLineColor}" Margin="0,0,0,8" Checked="checkbox_changed" Unchecked="checkbox_changed"/>
            <CheckBox x:Name="_chk_foreground_pattern" Content="{DynamicResource Spectrum.Checkboxes.ApplyForegroundPattern}" Margin="0,0,0,8" Checked="checkbox_changed" Unchecked="checkbox_changed"/>
            <CheckBox x:Name="_chk_background_pattern" Content="{DynamicResource Spectrum.Checkboxes.ApplyBackgroundPattern}" Margin="0,0,0,16" Checked="checkbox_changed" Unchecked="checkbox_changed"/>

            <TextBlock Text="Surface Transparency (%)" Foreground="#8E8E93" FontSize="11" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="_slider_transparency" Grid.Column="0" Minimum="0" Maximum="100" Value="0" TickFrequency="10" IsSnapToTickEnabled="True" Margin="0,0,10,0" ValueChanged="slider_transparency_changed" VerticalAlignment="Center"/>
                <TextBlock x:Name="_txt_transparency_val" Grid.Column="1" Text="0%" VerticalAlignment="Center" HorizontalAlignment="Right" FontWeight="SemiBold"/>
            </Grid>

            <Button x:Name="_button_create_legend" Content="{DynamicResource Spectrum.Buttons.CreateLegend}" Height="28" Style="{StaticResource MacButtonStyle}" Margin="0,0,0,8" Click="button_click_create_legend"/>
            <Button x:Name="_button_create_view_filters" Content="{DynamicResource Spectrum.Buttons.CreateViewFilters}" Height="28" Style="{StaticResource MacButtonStyle}" Margin="0,0,0,10" Click="button_click_create_view_filters"/>
            
            <TextBlock x:Name="_txt_block5" Text="{DynamicResource Spectrum.Messages.SpacesColorScheme}" Foreground="#FF3B30" FontSize="11" TextWrapping="Wrap" Visibility="Collapsed"/>
        </StackPanel>

        <Grid Grid.Column="2" Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="_button_reset_colors" Grid.Column="0" Content="{DynamicResource Spectrum.Buttons.Reset}" Height="34" Style="{StaticResource MacButtonStyle}" Click="button_click_reset"/>
            <Button x:Name="_button_set_colors" Grid.Column="2" Content="{DynamicResource Spectrum.Buttons.SetColors}" Height="34" Style="{StaticResource MacPrimaryButtonStyle}" Click="button_click_set_colors"/>
        </Grid>

    </Grid>
</Window>