<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="P13 COMMAND CENTER" Height="850" Width="650"
        Background="#0b0f19" FontFamily="Consolas" WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#00ffcc"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1e293b"/>
            <Setter Property="Foreground" Value="#e0f2f1"/>
            <Setter Property="BorderBrush" Value="#ff007f"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#05080f"/>
            <Setter Property="Foreground" Value="#e0f2f1"/>
            <Setter Property="BorderBrush" Value="#00ffcc"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#05080f"/>
            <Setter Property="Foreground" Value="#000000"/> 
            <Setter Property="BorderBrush" Value="#00ffcc"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#002b24"/>
            <Setter Property="Foreground" Value="#00ffcc"/>
            <Setter Property="BorderBrush" Value="#00ffcc"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Dest Header -->
            <RowDefinition Height="Auto"/> <!-- Dest Search -->
            <RowDefinition Height="*"/>    <!-- Dest List -->
            
            <RowDefinition Height="Auto"/> <!-- Legend Header -->
            <RowDefinition Height="Auto"/> <!-- Legend Search -->
            <RowDefinition Height="*"/>    <!-- Legend List -->

            <RowDefinition Height="Auto"/> <!-- Drafting Header -->
            <RowDefinition Height="Auto"/> <!-- Drafting Search -->
            <RowDefinition Height="*"/>    <!-- Drafting List -->

            <RowDefinition Height="Auto"/> <!-- Protocol Header -->
            <RowDefinition Height="Auto"/> <!-- Protocol Combo -->
            <RowDefinition Height="60"/>   <!-- Button -->
        </Grid.RowDefinitions>

        <!-- [STEP 1] DESTINATION NODES -->
        <TextBlock Grid.Row="0" Text="⚡ [STEP 1] SELECT DESTINATION NODES" FontWeight="Bold" Foreground="#ff007f"/>
        <TextBox Grid.Row="1" x:Name="DestSearch" Text="Search Destination..." Foreground="Gray" GotFocus="RemovePlaceholder" LostFocus="AddPlaceholder"/>
        <ListBox Grid.Row="2" x:Name="DestDocsList" SelectionMode="Extended" ToolTip="Standard Windows Selection (Shift/Ctrl) enabled."/>

        <!-- [STEP 2.1] LEGENDS -->
        <TextBlock Grid.Row="3" Text="💠 [STEP 2.1] SELECT SOURCE: LEGENDS" FontWeight="Bold" Foreground="#ff007f"/>
        <TextBox Grid.Row="4" x:Name="LegendSearch" Text="Search Legends..." Foreground="Gray" GotFocus="RemovePlaceholder" LostFocus="AddPlaceholder"/>
        <ListBox Grid.Row="5" x:Name="LegendViewsList" SelectionMode="Extended" ToolTip="Standard Windows Selection (Shift/Ctrl) enabled."/>

        <!-- [STEP 2.2] DRAFTING VIEWS -->
        <TextBlock Grid.Row="6" Text="💠 [STEP 2.2] SELECT SOURCE: DRAFTING VIEWS" FontWeight="Bold" Foreground="#ff007f"/>
        <TextBox Grid.Row="7" x:Name="DraftingSearch" Text="Search Drafting Views..." Foreground="Gray" GotFocus="RemovePlaceholder" LostFocus="AddPlaceholder"/>
        <ListBox Grid.Row="8" x:Name="DraftingViewsList" SelectionMode="Extended" ToolTip="Standard Windows Selection (Shift/Ctrl) enabled."/>

        <!-- [STEP 3] TRANSFER PROTOCOL -->
        <TextBlock Grid.Row="9" Text="⚙️ [STEP 3] TRANSFER PROTOCOL" FontWeight="Bold" Foreground="#ff007f"/>
        <ComboBox Grid.Row="10" x:Name="ModeCombo">
            <ComboBoxItem Content="💠 DIRECT TRANSFER (Keep Original Types)"/>
            <ComboBoxItem Content="⚡ COMPILE AS DRAFTING (Convert all to Drafting)"/>
            <ComboBoxItem Content="🌟 SYNTHESIZE AS LEGEND (Dest. must have >=1 Legend)"/>
        </ComboBox>

        <Button Grid.Row="11" x:Name="ExecuteBtn" Content="/// INITIATE NEURAL TRANSFER ///" Click="ExecuteTransfer" Margin="0,15,0,0"/>
    </Grid>
</Window>