<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rotate Fitting" Height="580" Width="300" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#DDDDDD"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Select Angle:" Margin="0,0,0,10" FontSize="14"/>

        <Button Grid.Row="1" Grid.Column="0" Content="5°" Click="angle_click" Tag="5"/>
        <Button Grid.Row="1" Grid.Column="1" Content="-5°" Click="angle_click" Tag="-5" Foreground="Red"/>

        <Button Grid.Row="2" Grid.Column="0" Content="11.25°" Click="angle_click" Tag="11.25"/>
        <Button Grid.Row="2" Grid.Column="1" Content="-11.25°" Click="angle_click" Tag="-11.25" Foreground="Red"/>

        <Button Grid.Row="3" Grid.Column="0" Content="22.5°" Click="angle_click" Tag="22.5"/>
        <Button Grid.Row="3" Grid.Column="1" Content="-22.5°" Click="angle_click" Tag="-22.5" Foreground="Red"/>

        <Button Grid.Row="4" Grid.Column="0" Content="30°" Click="angle_click" Tag="30"/>
        <Button Grid.Row="4" Grid.Column="1" Content="-30°" Click="angle_click" Tag="-30" Foreground="Red"/>

        <Button Grid.Row="5" Grid.Column="0" Content="45°" Click="angle_click" Tag="45"/>
        <Button Grid.Row="5" Grid.Column="1" Content="-45°" Click="angle_click" Tag="-45" Foreground="Red"/>

        <Button Grid.Row="6" Grid.Column="0" Content="60°" Click="angle_click" Tag="60"/>
        <Button Grid.Row="6" Grid.Column="1" Content="-60°" Click="angle_click" Tag="-60" Foreground="Red"/>

        <Button Grid.Row="7" Grid.Column="0" Content="90°" Click="angle_click" Tag="90"/>
        <Button Grid.Row="7" Grid.Column="1" Content="-90°" Click="angle_click" Tag="-90" Foreground="Red"/>

        <Button Grid.Row="8" Grid.ColumnSpan="2" Content="180°" Click="angle_click" Tag="180" Margin="5,15,5,5"/>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="5,15,5,5">
            <TextBlock Text="Custom Angle: " VerticalAlignment="Center" FontSize="14"/>
            <TextBox Name="custom_angle_box" Width="100" VerticalContentAlignment="Center" FontSize="14" Text="0"/>
        </StackPanel>

        <StackPanel Grid.Row="10" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Ok" Width="100" Click="ok_click"/>
            <Button Content="Cancel" Width="100" Click="cancel_click"/>
        </StackPanel>
    </Grid>
</Window>