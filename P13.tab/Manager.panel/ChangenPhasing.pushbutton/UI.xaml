<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="S-Filter: Advanced Phasing Edition" Height="850" Width="1050" WindowStartupLocation="CenterScreen" Background="#F4F5F7" FontFamily="Segoe UI" FontSize="12" Topmost="True">
    
    <Window.Resources>
        <Style TargetType="TreeViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5.5*"/>
            <ColumnDefinition Width="4.5*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Tree View -->
        <Border Grid.Column="0" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,15,0" CornerRadius="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F9FAFB" Padding="10" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="Model Elements" HorizontalAlignment="Left" FontWeight="Bold" VerticalAlignment="Center" Foreground="#374151"/>
                        <TextBlock Text="Count" HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center" Foreground="#374151"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="#EBF5FF" Padding="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍 Search (Enter): " VerticalAlignment="Center" FontWeight="Bold" Foreground="#1E3A8A"/>
                        <TextBox x:Name="txt_search" Grid.Column="1" Height="24" VerticalContentAlignment="Center" BorderBrush="#BFDBFE" BorderThickness="1" Padding="5,0"/>
                    </Grid>
                </Border>

                <TreeView x:Name="ui_treeview" Grid.Row="2" BorderThickness="0" Margin="5">
                </TreeView>
            </Grid>
        </Border>

        <!-- Right Panel: Controls -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tree Controls -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                <Button x:Name="btn_expand_all" Content="+" Width="26" Height="26" Margin="0,0,4,0" Background="White" BorderBrush="#D1D5DB" ToolTip="Expand All"/>
                <Button x:Name="btn_collapse_all" Content="-" Width="26" Height="26" Margin="0,0,15,0" Background="White" BorderBrush="#D1D5DB" ToolTip="Collapse All"/>
                <Button x:Name="btn_check_all" Content="☑" Width="26" Height="26" Margin="0,0,4,0" Background="White" BorderBrush="#D1D5DB" ToolTip="Check All"/>
                <Button x:Name="btn_uncheck_all" Content="☐" Width="26" Height="26" Margin="0,0,4,0" Background="White" BorderBrush="#D1D5DB" ToolTip="Uncheck All"/>
                <Button x:Name="btn_invert_all" Content="⮂" Width="26" Height="26" Margin="0,0,5,0" Background="#FEF3C7" BorderBrush="#F59E0B" ToolTip="Invert Selection"/>
            </StackPanel>

            <!-- 1. Source & Grouping -->
            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="1. Filtering &amp; Grouping System:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#1F2937"/>
                <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" Padding="10" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Tree View Grouping Method:" Foreground="#6B7280" Margin="0,0,0,4"/>
                        <ComboBox x:Name="cmb_grouping" SelectedIndex="0" Margin="0,0,0,10" Height="24">
                            <ComboBoxItem Content="Default (Category > Type)"/>
                            <ComboBoxItem Content="By Level (Level > Category > Type)"/>
                            <ComboBoxItem Content="By Workset (Workset > Category > Type)"/>
                        </ComboBox>
                        
                        <CheckBox x:Name="chk_include_links" Content="Include Linked Models (Read-only)" Margin="0,0,0,10" Foreground="#2563EB" FontWeight="SemiBold"/>
                        <Separator Margin="0,5,0,10" Background="#E5E7EB"/>
                        
                        <RadioButton x:Name="rad_current_sel" Content="Current Selection" Margin="0,3"/>
                        <RadioButton x:Name="rad_visible_view" Content="Elements Visible in Active View" IsChecked="True" Margin="0,3"/>
                        <RadioButton x:Name="rad_all_model" Content="Entire Model Elements" Margin="0,3"/>
                        
                        <Button x:Name="btn_filter_param" Content="▤ Advanced Parameter Filter" Height="28" Margin="0,10,0,0" Background="#ECFDF5" BorderBrush="#34D399" FontWeight="SemiBold" Foreground="#065F46"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 2. Auto-Expand Selection -->
            <StackPanel Grid.Row="2" Margin="0,0,0,15">
                <TextBlock Text="2. Auto-Expand Selection:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#1F2937"/>
                <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" Padding="10" CornerRadius="4">
                    <StackPanel>
                        <CheckBox x:Name="chk_exp_host" Content="Include Element Hosts" Margin="0,3"/>
                        <CheckBox x:Name="chk_exp_level" Content="Include Elements on Same Level" Margin="0,3"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 3. Phasing Control (NEW SYSTEM) -->
            <StackPanel Grid.Row="3" Margin="0,0,0,15">
                <TextBlock Text="3. Batch Phasing Control:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#1F2937"/>
                <Border Background="#F5F3FF" BorderBrush="#8B5CF6" BorderThickness="2" Padding="15" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Target Phase Created:" FontWeight="SemiBold" Foreground="#4C1D95" Margin="0,0,0,2"/>
                        <ComboBox x:Name="cmb_phase_created" Margin="0,0,0,10" Height="26" FontWeight="SemiBold"/>

                        <TextBlock Text="Target Phase Demolished:" FontWeight="SemiBold" Foreground="#4C1D95" Margin="0,0,0,2"/>
                        <ComboBox x:Name="cmb_phase_demolished" Margin="0,0,0,15" Height="26" FontWeight="SemiBold"/>

                        <Button x:Name="btn_apply_phasing" Content="⚡ APPLY PHASING" Height="45" Background="#8B5CF6" Foreground="White" BorderThickness="0" FontSize="14" FontWeight="Bold" ToolTip="Update phasing for all checked items in the Tree View"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 4. Memory & View Actions -->
            <StackPanel Grid.Row="4" VerticalAlignment="Bottom" Margin="0,10,0,0">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btn_save_mem" Grid.Column="0" Content="Save Memory" Height="28" Margin="0,0,3,0" Background="#FEF3C7" BorderBrush="#FBBF24" Foreground="#92400E" FontWeight="SemiBold"/>
                    <Button x:Name="btn_restore_mem" Grid.Column="1" Content="Restore Memory" Height="28" Margin="3,0,0,0" Background="#E0E7FF" BorderBrush="#818CF8" Foreground="#3730A3" FontWeight="SemiBold"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btn_run" Grid.Column="0" Content="Select" Height="35" Margin="0,0,3,0" FontWeight="Bold" Background="White" BorderBrush="#9CA3AF" BorderThickness="1"/>
                    <Button x:Name="btn_isolate" Grid.Column="1" Content="Isolate" Height="35" Margin="3,0,3,0" FontWeight="Bold" Background="White" BorderBrush="#9CA3AF" BorderThickness="1"/>
                    <Button x:Name="btn_highlight" Grid.Column="2" Content="Highlight" Height="35" Margin="3,0,3,0" FontWeight="Bold" Background="White" BorderBrush="#9CA3AF" BorderThickness="1"/>
                    <Button x:Name="btn_hide" Grid.Column="3" Content="Hide" Height="35" Margin="3,0,0,0" FontWeight="Bold" Background="White" BorderBrush="#9CA3AF" BorderThickness="1"/>
                </Grid>
            </StackPanel>

        </Grid>
    </Grid>
</Window>