<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="S-Filter (Pro Edition)" Height="800" Width="950" WindowStartupLocation="CenterScreen" Background="#F0F0F0" FontFamily="Segoe UI" FontSize="12" Topmost="True">
    
    <Window.Resources>
        <Style TargetType="TreeViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5.5*"/>
            <ColumnDefinition Width="4.5*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F0F0F0" Padding="5">
                    <Grid>
                        <TextBlock Text="Elements" HorizontalAlignment="Left" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="Count" HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="#E1EDF8" Padding="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍 Search (กด Enter เพื่อค้นหา): " VerticalAlignment="Center" FontWeight="Bold" Foreground="#4A7AAA"/>
                        <TextBox x:Name="txt_search" Grid.Column="1" Height="22" VerticalContentAlignment="Center"/>
                    </Grid>
                </Border>

                <TreeView x:Name="ui_treeview" Grid.Row="2" BorderThickness="0">
                </TreeView>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="5,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="btn_expand_all" Content="+" Width="22" Height="22" Margin="0,0,2,0" Background="White" ToolTip="Expand All"/>
                <Button x:Name="btn_collapse_all" Content="-" Width="22" Height="22" Margin="0,0,10,0" Background="White" ToolTip="Collapse All"/>
                <Button x:Name="btn_check_all" Content="☑" Width="22" Height="22" Margin="0,0,2,0" Background="White" ToolTip="Check All"/>
                <Button x:Name="btn_uncheck_all" Content="☐" Width="22" Height="22" Margin="0,0,2,0" Background="White" ToolTip="Uncheck All"/>
                <Button x:Name="btn_invert_all" Content="⮂" Width="22" Height="22" Margin="0,0,5,0" Background="#FFF5E6" BorderBrush="#FFC080" ToolTip="Invert Selection (สลับการเลือก)"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Select Source:" FontWeight="Bold" Margin="0,0,0,5"/>
                <Border Background="White" BorderBrush="#D0D0D0" BorderThickness="1" Padding="5">
                    <StackPanel>
                        <RadioButton x:Name="rad_current_sel" Content="Current Selection" Margin="0,2"/>
                        <RadioButton x:Name="rad_visible_view" Content="Elements Visible in View" IsChecked="True" Margin="0,2"/>
                        <RadioButton x:Name="rad_belong_view" Content="Elements Belonging View" Margin="0,2"/>
                        <RadioButton x:Name="rad_all_model" Content="All Model Elements" Margin="0,2"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,15">
                <TextBlock Text="Auto-Expand Selection (ขยายการเลือก):" FontWeight="Bold" Margin="0,0,0,5"/>
                <Border Background="White" BorderBrush="#D0D0D0" BorderThickness="1" Padding="5">
                    <StackPanel>
                        <CheckBox x:Name="chk_exp_host" Content="Include Host of Elements" Margin="0,3"/>
                        <CheckBox x:Name="chk_exp_level" Content="Include Same Level" Margin="0,3"/>
                        <CheckBox x:Name="chk_exp_workset" Content="Include Same Workset" Margin="0,3"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,0,15">
                <TextBlock Text="Deep Filter:" FontWeight="Bold" Margin="0,0,0,5"/>
                <Button x:Name="btn_filter_param" Content="Refine by Parameter (กรองด้วยพารามิเตอร์)" Height="30" Background="#E8F4E8" BorderBrush="#A3D9A5" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,0,0,15">
                <TextBlock Text="Memory (ความจำ):" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btn_save_mem" Grid.Column="0" Content="Save Checked" Height="28" Margin="0,0,3,0" Background="#FFF2CC" BorderBrush="#D6B656" FontWeight="Bold" ToolTip="จำวัตถุที่ติ๊กถูกไว้"/>
                    <Button x:Name="btn_restore_mem" Grid.Column="1" Content="Restore to Revit" Height="28" Margin="3,0,0,0" Background="#E1D5E7" BorderBrush="#9673A6" FontWeight="Bold" ToolTip="เลือกวัตถุที่เคยจำไว้ลงใน Revit"/>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="5" VerticalAlignment="Bottom" Margin="0,10,0,0">
                <TextBlock x:Name="lbl_status_count" Text="0" FontSize="18" FontWeight="Bold"/>
                <TextBlock Text="elements checked in Tree View" Margin="0,0,0,10" Foreground="Gray"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button x:Name="btn_run" Grid.Column="0" Content="Select" Height="40" Margin="0,0,5,0" FontWeight="Bold" Background="#E1EDF8" BorderBrush="#8DA6CE" BorderThickness="2"/>
                    <Button x:Name="btn_isolate" Grid.Column="1" Content="Isolate" Height="40" Margin="0,0,5,0" FontWeight="Bold" Background="#FFF0F0" BorderBrush="#F4A2A2" BorderThickness="2" ToolTip="แยกแสดงผลชั่วคราว"/>
                    <Button x:Name="btn_hide" Grid.Column="2" Content="Hide" Height="40" FontWeight="Bold" Background="#F0F0F0" BorderBrush="#C0C0C0" BorderThickness="2" ToolTip="ซ่อนวัตถุชั่วคราว"/>
                </Grid>
            </StackPanel>

        </Grid>
    </Grid>
</Window>