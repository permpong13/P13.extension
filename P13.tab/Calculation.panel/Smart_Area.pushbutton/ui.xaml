<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Area Tool" Height="420" Width="400" 
        Background="#1E1E1E" WindowStartupLocation="CenterScreen" 
        WindowStyle="ToolWindow" Topmost="True">
    
    <Border Padding="20">
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="📐 SMART AREA FINDER" Foreground="#00E676" 
                       FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            
            <Border Background="#2D2D2D" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <!-- Settings -->
                    <CheckBox x:Name="CheckAccumulate" Content="เปิดโหมดสะสมพื้นที่ (วัดต่อเนื่องหลายห้อง)" 
                              Foreground="White" Margin="0,0,0,10" FontSize="13"/>
                    
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="ประเมินราคา (บาท/ตร.ม.): " Foreground="#CCCCCC" FontSize="13" VerticalAlignment="Center"/>
                        <TextBox x:Name="CostInput" Width="100" Height="25" Background="#1E1E1E" 
                                 Foreground="White" BorderBrush="#555555" TextAlignment="Right" Text="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Action Buttons -->
            <Button x:Name="BtnPickPoints" Height="45" Background="#2962FF" Foreground="White" 
                    FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15" BorderThickness="0" Cursor="Hand">
                <Button.Content>
                    <TextBlock Text="1. คลิกจุดยอดมุม (มีเส้นไกด์ไลน์ชั่วคราว)" />
                </Button.Content>
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
            
            <Button x:Name="BtnSelectRegion" Height="45" Background="#FF6D00" Foreground="White" 
                    FontSize="14" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                <Button.Content>
                    <TextBlock Text="2. เลือกชิ้นงานที่วาดไว้ (ลบทิ้งอัตโนมัติ)" />
                </Button.Content>
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
            
            <TextBlock Text="* ระบบจะ Copy ผลลัพธ์ลง Clipboard ให้อัตโนมัติ" 
                       Foreground="#888888" FontSize="11" FontStyle="Italic" 
                       HorizontalAlignment="Center" Margin="0,15,0,0"/>
        </StackPanel>
    </Border>
</Window>