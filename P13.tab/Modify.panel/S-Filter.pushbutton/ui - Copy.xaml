<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="S-Filter" Height="800" Width="900" WindowStartupLocation="CenterScreen" Background="#F0F0F0" FontFamily="Segoe UI" FontSize="12">
    
    <Window.Resources>
        <Style TargetType="TreeViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5.5*"/>
            <ColumnDefinition Width="4.5*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F0F0F0" Padding="5,5,5,5">
                    <Grid>
                        <TextBlock Text="Elements" HorizontalAlignment="Left" FontWeight="Bold"/>
                        <TextBlock Text="Count" HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,15,0"/>
                    </Grid>
                </Border>

                <TreeView x:Name="ui_treeview" Grid.Row="2" BorderThickness="0">
                </TreeView>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="5,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="btn_expand_all" Content="+" Width="20" Height="20" Margin="0,0,2,0" Background="White" ToolTip="Expand All"/>
                <Button x:Name="btn_collapse_all" Content="-" Width="20" Height="20" Margin="0,0,5,0" Background="White" ToolTip="Collapse All"/>
                <Button x:Name="btn_check_all" Content="☑" Width="20" Height="20" Margin="0,0,2,0" Background="White" ToolTip="Check All"/>
                <Button x:Name="btn_uncheck_all" Content="☐" Width="20" Height="20" Margin="0,0,5,0" Background="White" ToolTip="Uncheck All"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Select:" Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <RadioButton x:Name="rad_current_sel" Content="Current Selection" Margin="0,2"/>
                        <RadioButton x:Name="rad_visible_view" Content="Elements Visible in View" IsChecked="True" Margin="0,2"/>
                        <RadioButton x:Name="rad_belong_view" Content="Elements Belonging View" Margin="0,2"/>
                        <RadioButton x:Name="rad_all_model" Content="All Model Elements" Margin="0,2"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <CheckBox x:Name="chk_only_3d" Content="Only 3D Modeled" Margin="0,2"/>
                        <CheckBox x:Name="chk_only_anno" Content="Only Annotation" Margin="0,2"/>
                        <CheckBox x:Name="chk_has_box" Content="Has Bounding Box" Margin="0,2"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,15">
                <TextBlock Text="Expand Checked:" Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="What" Foreground="Gray" Margin="15,0,0,5"/>
                        <CheckBox Content="Same Category" Margin="0,2"/>
                        <CheckBox Content="Same Family" Margin="0,2"/>
                        <CheckBox Content="Same Type" Margin="0,2"/>
                        <CheckBox Content="Same Workset" Margin="0,2"/>
                        <CheckBox Content="Host of Elements" Margin="0,2"/>
                        <CheckBox Content="Hosted Elements" Margin="0,2"/>
                        <CheckBox Content="Nested Elements" Margin="0,2"/>
                        <CheckBox Content="Joined Elements" Margin="0,2"/>
                        <CheckBox Content="Supercomponent" Margin="0,2"/>
                        <CheckBox Content="Group or Assembly" Margin="0,2"/>
                        <CheckBox Content="Dependent" Margin="0,2"/>
                        <CheckBox Content="Intersects (Quick)" Margin="0,2"/>
                        <CheckBox Content="Same MEP System" Margin="0,2"/>
                        <Button Content="Expand Selection" Margin="0,10,10,0" Height="25" Background="#F0F0F0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Where" Foreground="Gray" Margin="0,0,0,5"/>
                        <RadioButton Content="All Model" IsChecked="True" Margin="0,2"/>
                        <RadioButton Content="Current View" Margin="0,2"/>
                        <TextBlock Text="How" Foreground="Gray" Margin="0,10,0,5"/>
                        <RadioButton Content="Add To Current" IsChecked="True" Margin="0,2"/>
                        <RadioButton Content="Create New" Margin="0,2"/>
                        <Border Background="#CBE4F9" Padding="5" Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="Unselect Element If:" Foreground="#4A7AAA" Margin="0,0,0,5"/>
                                <CheckBox Content="Belongs to Group" IsChecked="True" Margin="0,2"/>
                                <CheckBox Content="Belongs to Assembly" IsChecked="True" Margin="0,2"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,0,15">
                <TextBlock Text="Apply Filter to All :" Margin="0,0,0,5"/>
                <ComboBox SelectedIndex="0" Margin="0,0,0,10">
                    <ComboBoxItem Content="Views -All -Unreferenced"/>
                </ComboBox>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Keep Only" Width="70" Height="25" Margin="0,0,10,0" Background="#F0F0F0"/>
                    <Button Content="Remove" Width="70" Height="25" Background="#F0F0F0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="4" VerticalAlignment="Bottom" Margin="0,10,0,0">
                <TextBlock x:Name="lbl_status_count" Text="0" FontSize="18" FontWeight="Bold"/>
                <TextBlock Text="elements checked in current selection" Margin="0,0,0,10"/>
                <Button x:Name="btn_run" Content="S-Filter" Height="35" FontWeight="Bold" Background="#E1EDF8" BorderBrush="#8DA6CE" BorderThickness="2"/>
            </StackPanel>

        </Grid>
    </Grid>
</Window>